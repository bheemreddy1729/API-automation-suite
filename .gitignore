# Maven
target/

# Secrets / local config — never commit
.env
*.local
cloud_auth.json
.mcp.json
# Tenant secrets (use tenants.properties.example as the committed template)
src/test/resources/config/tenants.properties

# Allure
.allure/
allure-results/
allure-report/

# QA loop transient artifacts (test plans opened for review by /qa-start)
qa/

# Experiments — Node deps & lockfiles (the probe is run ad hoc)
experiments/**/node_modules/
experiments/**/package-lock.json

# Python engine artifacts
engine/**/__pycache__/
engine/**/*.egg-info/
engine/.venv/
*.pyc

# Eclipse (keep .project/.classpath/.settings so the project opens directly;
# ignore only transient Eclipse output)
bin/
.metadata/

# IntelliJ / VS Code
.idea/
*.iml
.vscode/

# OS
Thumbs.db
.DS_Store
