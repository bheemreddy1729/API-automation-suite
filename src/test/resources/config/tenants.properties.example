# Template for config/tenants.properties (which is git-ignored).
# Copy to config/tenants.properties and fill in real secrets, OR provide each
# secret via the env var TENANT_<id>_SECRET (e.g. TENANT_201_SECRET).

tenant.default=201

tenant.201.secret=<TENANT_201_SECRET>
tenant.201.role=vsim_admin
tenant.201.langCode=en
tenant.201.userId=1

