# Azure OpenAI — fill these, then copy this file to .env  (.env is git-ignored).
# The engine reads these via python-dotenv; nothing is hardcoded.

AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_API_KEY=<your-azure-openai-key>

# Optional with the Azure v1 GA API; otherwise pin a REST API version:
AZURE_OPENAI_API_VERSION=2024-10-21

# Per-task deployments — the model router maps TaskKind -> one of these deployment names.
# Point each at the Azure deployment you want for that kind of task.
AZURE_OPENAI_DEPLOYMENT_CODING=<deployment-for-coding-model>
AZURE_OPENAI_DEPLOYMENT_REASONING=<deployment-for-reasoning-model>
AZURE_OPENAI_DEPLOYMENT_CLASSIFICATION=<deployment-for-small-fast-model>
