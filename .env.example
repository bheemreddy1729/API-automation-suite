# Copy to ".env" and fill in. The ".env" file is git-ignored — never commit secrets.
# Load it into your shell before running mvn (PowerShell example shown per line),
# or export these as real environment variables / pass with -D to Maven.

# --- System under test ---
# $env:API_BASE_URI = "https://api.example.com"
API_BASE_URI=https://jsonplaceholder.typicode.com
API_BASE_PATH=
# none | bearer | apikey | basic
API_AUTH_TYPE=none
# Bearer token, API key, or base64("user:pass") for basic
API_AUTH_TOKEN=
# Header name used when API_AUTH_TYPE=apikey
API_AUTH_HEADER=x-api-key
API_TIMEOUT_MS=30000

# --- Jira Cloud (Atlassian Rovo MCP) ---
JIRA_BASE_URL=https://your-site.atlassian.net
JIRA_PROJECT_KEY=PROJ
JIRA_EMAIL=you@example.com
# API token from https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=

# --- Xray Cloud (results import) ---
# From Jira -> Xray -> API Keys
XRAY_CLIENT_ID=
XRAY_CLIENT_SECRET=
XRAY_BASE_URL=https://xray.cloud.getxray.app/api/v2
